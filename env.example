# ==============================
# Discord War Bot - Configuration
# ==============================

# Get from Discord Developer Portal > Your App > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# Get from Discord Developer Portal > Your App > General Information > Application ID
CLIENT_ID=your_client_id_here

# Right-click your server > Copy Server ID (enable Developer Mode first)
GUILD_ID=your_guild_id_here

# Right-click the voice channel > Copy Channel ID
VOICE_CHANNEL_ID=your_voice_channel_id_here

# Right-click the text channel > Copy Channel ID
TEXT_CHANNEL_ID=your_text_channel_id_here
